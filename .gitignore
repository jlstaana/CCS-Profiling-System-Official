# Root ignore rules
node_modules/
.env
.env.local
.env.*.local

# Frontend-specific
Frontend/dist/
Frontend/.vite/

# Backend-specific
Backend/vendor/
Backend/storage/*.key
Backend/storage/framework/sessions/*
Backend/storage/framework/views/*.php
Backend/storage/framework/cache/data/*
Backend/bootstrap/cache/*.php
Backend/.phpunit.result.cache
Backend/public/hot
Backend/public/storage
Backend/public/build

# Misc
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
