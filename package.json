{
  "name": "ccs-profiling-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "Frontend",
    "Backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w Frontend\" \"npm run dev -w Backend\"",
    "build": "npm run build -w Frontend && npm run build -w Backend",
    "install:all": "npm install && npm install -w Frontend && npm install -w Backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.1",
    "@rollup/rollup-win32-x64-msvc": "4.60.1",
    "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.12",
    "@rolldown/binding-win32-x64-msvc": "1.0.0-rc.12",
    "lightningcss-linux-x64-gnu": "1.32.0",
    "lightningcss-win32-x64-msvc": "1.32.0",
    "@tailwindcss/oxide-linux-x64-gnu": "4.0.0",
    "@tailwindcss/oxide-win32-x64-msvc": "4.0.0"
  }
}
